# Discord 봇 토큰 (필수)
DISCORD_TOKEN=TOKEN

# 명령어 접두사 (선택, 기본값: !)
COMMAND_PREFIX=!

# PostgreSQL 데이터베이스 URL (필수)
# 형식: postgresql://username:password@host:port/database
# 기본값: postgresql://root:root@localhost:5432/studydb
DATABASE_URL=postgresql://root:root@localhost:5432/studydb

# PostgreSQL 설정 (Docker Compose 사용 시)
POSTGRES_USER=root
POSTGRES_PASSWORD=root
POSTGRES_DB=studydb
POSTGRES_PORT=5432

# 크롤링 간격 (초 단위, 기본값: 3600 = 1시간)
CRAWL_INTERVAL=3600

# 로그 레벨 (선택, 기본값: INFO)
# 가능한 값: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 로그 파일명 (선택, 기본값: hotdeal_bot.log)
LOG_FILE=hotdeal_bot.log

# Anthropic API Key (선택)
# 설정 시 핫딜 1차 알림 3시간 후 AI 추천/비추천 2차 알림 기능이 활성화됩니다.
# 미설정 시 기존 봇 동작에 영향 없음
# 발급: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# AI 분석 지연 시간 (시간 단위, 기본값: 3)
AI_ANALYSIS_DELAY_HOURS=3
